# Copy to `.env` for optional developer defaults only.
# Expo injects variables prefixed with EXPO_PUBLIC_
# https://docs.expo.dev/guides/environment-variables/
#
# End users configure TMDB + OMSS in the app (onboarding / Settings). Build-time values here are optional
# fallbacks for local development when you skip onboarding.

# TMDB API v3 key — optional dev fallback; user key from onboarding takes precedence.
EXPO_PUBLIC_TMDB_API_KEY=

# CinePro Core (OMSS) base URL — optional dev fallback; user URL from onboarding takes precedence.
EXPO_PUBLIC_CINEPRO_BASE_URL=
